# DNSMonitor — Environment Variables
# Copy to .env.local for local dev
# Set ALL in Vercel Dashboard → Project → Settings → Environment Variables

# Supabase (safe for browser)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase (server/API only — NEVER expose to browser)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App
APP_URL=https://dnsmonitor.easysecurity.in
ALLOWED_ORIGIN=https://dnsmonitor.easysecurity.in

# Secrets — generate with: openssl rand -hex 32
CRON_SECRET=generate-a-random-32-char-hex-string
INGEST_API_SECRET=generate-a-different-random-32-char-hex-string

# Resend email (free tier: 3000 emails/month) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=DNSMonitor <alerts@easysecurity.in>
